{
  "name": "electron-syphon",
  "version": "0.1.0",
  "description": "Publish an Electron app's GPU frames to Syphon on macOS — zero-copy, from the main process.",
  "license": "MIT",
  "author": "kyeshmz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyeshmz/electron-spout.git"
  },
  "bugs": {
    "url": "https://github.com/kyeshmz/electron-spout/issues"
  },
  "homepage": "https://github.com/kyeshmz/electron-spout#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "gypfile": true,
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "prebuilds",
    "Frameworks",
    "native",
    "binding.gyp",
    "README.md"
  ],
  "scripts": {
    "install": "node-gyp-build",
    "build:native": "node-gyp rebuild",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:ts && npm run build:native",
    "prebuild": "prebuildify --napi --strip",
    "rebuild:electron": "electron-rebuild -f -w syphon_addon",
    "bench": "electron test/bench.js",
    "bench:scaling": "electron test/scaling-bench.js",
    "test": "node --expose-gc test/smoke.js",
    "test:atlas": "electron test/atlas-check.js && electron test/atlas-partial-check.js && electron test/atlas-pingpong-check.js",
    "test:composite": "npm run build:ts && electron test/composite-e2e.js && electron test/single-window-grid.js",
    "bench:load": "npm run build:ts && electron test/composite-load.js",
    "test:rate": "npm run build:ts && electron test/output-rate-load.js",
    "test:e2e": "npm --prefix examples/full-demo test",
    "make-library": "bash scripts/build-library.sh",
    "prepack": "npm run build:ts",
    "release": "commit-and-tag-version",
    "release:dry": "commit-and-tag-version --dry-run",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "release:patch": "commit-and-tag-version --release-as patch",
    "release:push": "git push --follow-tags origin main"
  },
  "dependencies": {
    "node-addon-api": "^8.3.1",
    "node-gyp-build": "^4.8.4"
  },
  "peerDependencies": {
    "electron": ">=33"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "commit-and-tag-version": "^12.7.3",
    "electron": "^42.3.2",
    "electron-rebuild": "^3.2.9",
    "node-gyp": "^11.2.0",
    "prebuildify": "^6.0.1",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "syphon",
    "electron",
    "macos",
    "metal",
    "iosurface",
    "shared-texture",
    "zero-copy",
    "video",
    "vj",
    "offscreen"
  ]
}
